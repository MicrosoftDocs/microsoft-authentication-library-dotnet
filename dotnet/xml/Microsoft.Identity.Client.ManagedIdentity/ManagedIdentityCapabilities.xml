      <ReturnValue>
        <ReturnType>System.Boolean</ReturnType>
      </ReturnValue>
      <Docs>
        <summary>
            Gets a value indicating whether the host can bind a token to a key (mTLS
            Proof-of-Possession).
            </summary>
        <value>
          <c>true</c> when <see cref="P:Microsoft.Identity.Client.ManagedIdentity.ManagedIdentityCapabilities.MaxSupportedBindingStrength" /> is greater than
            <see cref="F:Microsoft.Identity.Client.AppConfig.MtlsBindingStrength.None" />. This means the host can bind a token to a key;
            it does <b>not</b> imply hardware attestation. Callers that require attestation must
            check for the <see cref="F:Microsoft.Identity.Client.AppConfig.MtlsBindingStrength.KeyGuard" /> tier.
            </value>
        <remarks>To be added.</remarks>
      </Docs>
    </Member>
